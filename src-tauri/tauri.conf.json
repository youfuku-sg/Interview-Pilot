{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Interview-Pilot",
  "version": "0.5.2",
  "identifier": "com.interview-pilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Interview-Pilot - AIアシスタント",
        "width": 600,
        "height": 54,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "contentProtected": true,
        "focus": false,
        "acceptFirstMouse": true,
        "shadow": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["info.plist", "pluely.desktop"],
    "macOS": { "minimumSystemVersion": "10.13" },
    "windows": {
      "wix": { "language": ["ja-JP"] },
      "nsis": { "languages": ["Japanese"] }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pluely.db"]
    }
  }
}
